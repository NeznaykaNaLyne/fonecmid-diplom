#Область ПрограммныйИнтерфейс
// Отправляет текстовое сообщение в группу телеграм-бота.
//
// Параметры:
//  ТекстСообщения - Строка - текст для отправки.
//
// Возвращаемое значение:
//  Булево - Истина, если HTTP-ответ имеет код 200.
//
Функция ВКМ_ОтправитьСообщение(ТекстСообщения) Экспорт
	
	Токен = Константы.ВКМ_ТокенУправленияТелеграмБотом.Получить();
	ИдентификаторГруппы = Константы.ВКМ_ИдентификаторГруппыТелеграмДляОповещения.Получить();
	
	Если Не ЗначениеЗаполнено(Токен) Или Не ЗначениеЗаполнено(ИдентификаторГруппы) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL();
	Соединение = Новый HTTPСоединение("api.telegram.org",,,,, 30, ЗащищенноеСоединение);
	
	АдресРесурса = СтрШаблон("/bot%1/sendMessage", Токен);
	HTTPЗапрос = Новый HTTPЗапрос(АдресРесурса);
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	
	ПараметрыТела = Новый Структура;
	ПараметрыТела.Вставить("chat_id", ИдентификаторГруппы);
	ПараметрыТела.Вставить("text", ТекстСообщения);
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, ПараметрыТела);
	ТелоJSON = ЗаписьJSON.Закрыть();
	
	HTTPЗапрос.УстановитьТелоИзСтроки(ТелоJSON, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	HTTPОтвет = Соединение.ВызватьHTTPМетод("POST", HTTPЗапрос);
	
	Если HTTPОтвет.КодСостояния = 200 Тогда
		Возврат Истина;
	КонецЕсли;
	
	ТекстОшибки = HTTPОтвет.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
	ЗаписьЖурналаРегистрации(
		НСтр("ru = 'ВКМ.Телеграм'"),
		УровеньЖурналаРегистрации.Ошибка,,,
		СтрШаблон(
			НСтр("ru = 'Ошибка отправки сообщения в Telegram. Код состояния: %1. Ответ: %2'"),
			HTTPОтвет.КодСостояния,
			ТекстОшибки));
	
	Возврат Ложь;
	
КонецФункции

//
Процедура ВКМ_ДобавитьУведомление(ТекстСообщения) Экспорт
	
	Если Не ЗначениеЗаполнено(ТекстСообщения) Тогда
		Возврат;
	КонецЕсли;
	
	Уведомление = Справочники.ВКМ_УведомленияТелеграмБоту.СоздатьЭлемент();
	Уведомление.ВКМ_ТекстСообщения = ТекстСообщения;
	Уведомление.Записать();
	
КонецПроцедуры

//
Функция ВКМ_СформироватьТекстУведомленияОбОбслуживании(ДокументОбслуживания, ЭтоНовыйДокумент) Экспорт
	
	Если ЭтоНовыйДокумент Тогда
		ЗаголовокСообщения = НСтр("ru = 'Запланировано новое обслуживание клиента:'");
	Иначе
		ЗаголовокСообщения = НСтр("ru = 'Изменено планирование обслуживания клиента:'");
	КонецЕсли;
	
	ПредставлениеДокумента = ?(ЗначениеЗаполнено(ДокументОбслуживания.Ссылка),
		Строка(ДокументОбслуживания.Ссылка),
		НСтр("ru = '(новый документ)'"));
	
	ТекстСообщения =
		ЗаголовокСообщения + Символы.ПС
		+ НСтр("ru = 'Документ:'") + " " + ПредставлениеДокумента + Символы.ПС
		+ НСтр("ru = 'Клиент:'") + " " + ДокументОбслуживания.ВКМ_Клиент + Символы.ПС
		+ НСтр("ru = 'Договор:'") + " " + ДокументОбслуживания.ВКМ_Договор + Символы.ПС
		+ НСтр("ru = 'Специалист:'") + " " + ДокументОбслуживания.ВКМ_Специалист + Символы.ПС
		+ НСтр("ru = 'Дата проведения работ:'") + " " + Формат(ДокументОбслуживания.ВКМ_ДатаПроведенияРабот, "ДЛФ=D") + Символы.ПС
		+ НСтр("ru = 'Время начала (план):'") + " " + Формат(ДокументОбслуживания.ВКМ_ВремяНачалаРаботПлан, "ДЛФ=T") + Символы.ПС
		+ НСтр("ru = 'Время окончания (план):'") + " " + Формат(ДокументОбслуживания.ВКМ_ВремяНачалаРаботПлан, "ДЛФ=T") + Символы.ПС
		+ НСтр("ru = 'Описание проблемы:'") + " " + ДокументОбслуживания.ВКМ_ОписаниеПроблемы;
	
	Возврат ТекстСообщения;
	
КонецФункции

//
Процедура ВКМ_ОтправкаУведомленийТелеграм() Экспорт
	
	Выборка = Справочники.ВКМ_УведомленияТелеграмБоту.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если ВКМ_ОтправитьСообщение(Выборка.ВКМ_ТекстСообщения) Тогда
			ОбъектУведомления = Выборка.Ссылка.ПолучитьОбъект();
			ОбъектУведомления.Удалить();
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры
#КонецОбласти