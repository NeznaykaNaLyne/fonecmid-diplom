Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	Движения.ВКМ_ДополнительныеНачисления.Записывать = Истина;
	Движения.ВКМ_Удержания.Записывать = Истина;
	Движения.ВКМ_ВзаиморасчетыССотрудниками.Записывать = Истина;
	
	Для Каждого СтрокаСотрудника Из СписокСотрудников Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаСотрудника.Сотрудник) Тогда
			Продолжить;
		КонецЕсли;
		
		СуммаПремии = ?(ЗначениеЗаполнено(СтрокаСотрудника.СуммаПремии), СтрокаСотрудника.СуммаПремии, 0);
		
		Если СуммаПремии < 0 Тогда
			Отказ = Истина;
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Сумма премии не может быть отрицательной. Сотрудник: " + СтрокаСотрудника.Сотрудник;
			Сообщение.Сообщить();
			Возврат;
		КонецЕсли;
		
		СуммаНДФЛ = Окр(СуммаПремии * 0.13, 2);
		СуммаКВыплате = СуммаПремии - СуммаНДФЛ;
		
		СтрокаСотрудника.СуммаНДФЛ = СуммаНДФЛ;
		СтрокаСотрудника.СуммаКВыплате = СуммаКВыплате;
		
		ДвижениеНачисление = Движения.ВКМ_ДополнительныеНачисления.Добавить();
		ДвижениеНачисление.ПериодРегистрации = Дата;
		ДвижениеНачисление.Сотрудник = СтрокаСотрудника.Сотрудник;
		ДвижениеНачисление.ВидРасчета = ПланыВидовРасчета.ВКМ_ДополнительныеНачисления.ВКМ_ФиксированнаяПремия;
		ДвижениеНачисление.Результат = СуммаПремии;
		
		Если СуммаНДФЛ <> 0 Тогда
			ДвижениеУдержание = Движения.ВКМ_Удержания.Добавить();
			ДвижениеУдержание.ПериодРегистрации = Дата;
			ДвижениеУдержание.Сотрудник = СтрокаСотрудника.Сотрудник;
			ДвижениеУдержание.ВидРасчета = ПланыВидовРасчета.ВКМ_Удержания.ВКМ_НДФЛ;
			ДвижениеУдержание.Результат = СуммаНДФЛ;
		КонецЕсли;
		
		ДвижениеВзаиморасчеты = Движения.ВКМ_ВзаиморасчетыССотрудниками.Добавить();
		ДвижениеВзаиморасчеты.Период = Дата;
		ДвижениеВзаиморасчеты.ВидДвижения = ВидДвиженияНакопления.Приход;
		ДвижениеВзаиморасчеты.Сотрудник = СтрокаСотрудника.Сотрудник;
		ДвижениеВзаиморасчеты.Сумма = СуммаКВыплате;
		
	КонецЦикла;
	
КонецПроцедуры