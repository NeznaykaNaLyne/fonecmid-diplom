Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	
	Движения.ВКМ_ОсновныеНачисления.Записывать = Истина;
	Движения.ВКМ_Удержания.Записывать = Истина;
	Движения.ВКМ_ВзаиморасчетыССотрудниками.Записывать = Истина;
	
	ДатаРасчета = ?(ЗначениеЗаполнено(ВКМ_МесяцНачисления), ВКМ_МесяцНачисления, Дата);
	НачалоПериода = НачалоМесяца(ДатаРасчета);
	КонецПериода  = КонецМесяца(ДатаРасчета);
	
	Для Каждого СтрокаСотрудника Из Сотрудники Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаСотрудника.Сотрудник) Тогда
			Продолжить;
		КонецЕсли;
		
		УсловияОплаты = ВКМ_ПолучитьУсловияОплатыСотрудника(СтрокаСотрудника.Сотрудник, КонецПериода);
		Если Не УсловияОплаты.ЕстьУсловия Тогда
			Отказ = Истина;
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Для сотрудника " + СтрокаСотрудника.Сотрудник + " не заданы условия оплаты.";
			Сообщение.Сообщить();
			Возврат;
		КонецЕсли;
		
		Оклад = УсловияОплаты.Оклад;
		СуммаОтРабот = ВКМ_ПолучитьСуммуОтРаботЗаПериод(СтрокаСотрудника.Сотрудник, НачалоПериода, КонецПериода);
		Отпускные = 0;
		Начислено = Оклад + СуммаОтРабот + Отпускные;
		НДФЛ = Окр(Начислено * 0.13, 2);
		КВыплате = Начислено - НДФЛ;
		
		СтрокаСотрудника.СуммаОклада = Оклад;
		СтрокаСотрудника.СуммаПроцентОтРабот = СуммаОтРабот;
		СтрокаСотрудника.СуммаОтпускных = Отпускные;
		СтрокаСотрудника.СуммаНачислено = Начислено;
		СтрокаСотрудника.СуммаНДФЛ = НДФЛ;
		СтрокаСотрудника.СуммаКВыплате = КВыплате;
		
		ДвижениеОсн = Движения.ВКМ_ОсновныеНачисления.Добавить();
		ДвижениеОсн.ПериодРегистрации = Дата;
		ДвижениеОсн.Сотрудник = СтрокаСотрудника.Сотрудник;
		ДвижениеОсн.ВидРасчета = ПланыВидовРасчета.ВКМ_ОсновныеНачисления.ВКМ_Оклад;
		ДвижениеОсн.Результат = Оклад;
		
		Если СуммаОтРабот <> 0 Тогда
			ДвижениеОсн = Движения.ВКМ_ОсновныеНачисления.Добавить();
			ДвижениеОсн.ПериодРегистрации = Дата;
			ДвижениеОсн.Сотрудник = СтрокаСотрудника.Сотрудник;
			ДвижениеОсн.ВидРасчета = ПланыВидовРасчета.ВКМ_ОсновныеНачисления.ВКМ_ПроцентОтРабот;
			ДвижениеОсн.Результат = СуммаОтРабот;
		КонецЕсли;
		
		Если НДФЛ <> 0 Тогда
			ДвижениеУдерж = Движения.ВКМ_Удержания.Добавить();
			ДвижениеУдерж.ПериодРегистрации = Дата;
			ДвижениеУдерж.Сотрудник = СтрокаСотрудника.Сотрудник;
			ДвижениеУдерж.ВидРасчета = ПланыВидовРасчета.ВКМ_Удержания.ВКМ_НДФЛ;
			ДвижениеУдерж.Результат = НДФЛ;
		КонецЕсли;
		
		ДвижениеВзаиморасчеты = Движения.ВКМ_ВзаиморасчетыССотрудниками.Добавить();
		ДвижениеВзаиморасчеты.Период = Дата;
		ДвижениеВзаиморасчеты.ВидДвижения = ВидДвиженияНакопления.Приход;
		ДвижениеВзаиморасчеты.Сотрудник = СтрокаСотрудника.Сотрудник;
		ДвижениеВзаиморасчеты.Сумма = КВыплате;
		
	КонецЦикла;
	
КонецПроцедуры
Функция ВКМ_ПолучитьУсловияОплатыСотрудника(Сотрудник, ДатаСреза)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Условия.Оклад КАК Оклад,
	|	Условия.ПроцентОтРабот КАК ПроцентОтРабот
	|ИЗ
	|	РегистрСведений.ВКМ_УсловияОплатыСотрудников.СрезПоследних(
	|		&ДатаСреза,
	|		Сотрудник = &Сотрудник) КАК Условия";
	
	Запрос.УстановитьПараметр("ДатаСреза", ДатаСреза);
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Новый Структура("ЕстьУсловия, Оклад, ПроцентОтРабот", Истина, Выборка.Оклад, Выборка.ПроцентОтРабот);
	КонецЕсли;
	
	Возврат Новый Структура("ЕстьУсловия, Оклад, ПроцентОтРабот", Ложь, 0, 0);
	
КонецФункции
Функция ВКМ_ПолучитьСуммуОтРаботЗаПериод(Сотрудник, НачалоПериода, КонецПериода)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(Обороты.ВКМ_СуммаКОплатеОборот), 0) КАК СуммаОтРабот
	|ИЗ
	|	РегистрНакопления.ВКМ_ВыполненныеСотрудникомРаботы.Обороты(
	|		&НачалоПериода,
	|		&КонецПериода,
	|		,
	|		Сотрудник = &Сотрудник) КАК Обороты";
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.СуммаОтРабот;
	КонецЕсли;
	
	Возврат 0;
КонецФункции	