#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
#Область ОбработчикиСобытий

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	//++ ВКМ
	ВКМ_ПроверитьУсловияПроведения(Отказ);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	//-- ВКМ
	
	Движения.ВКМ_ВыполненныеКлиентуРаботы.Записывать = Истина;
	Движения.ВКМ_ВыполненныеСотрудникомРаботы.Записывать = Истина;
	
	//++ ВКМ
	ВКМ_СформироватьДвиженияПоВыполненнымРаботам();
	//-- ВКМ
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	//++ ВКМ
		
		ЭтоНовыйДокумент = Не ЗначениеЗаполнено(Ссылка);
		НужноУведомление = ЭтоНовыйДокумент;
		
		Если Не ЭтоНовыйДокумент Тогда
			
			СтарыеЗначения = ВКМ_ПолучитьСохраненныеЗначенияДляУведомления();
			
			НужноУведомление = (ВКМ_ДатаПроведенияРабот <> СтарыеЗначения.ДатаПроведенияРабот)
	Или (ВКМ_ВремяНачалаРаботПлан <> СтарыеЗначения.ВремяНачалаРабот)
	Или (ВКМ_ВремяОкончанияРаботПлан <> СтарыеЗначения.ВремяОкончанияРабот)
	Или (ВКМ_Специалист <> СтарыеЗначения.Специалист);
			
		КонецЕсли;
		
		Если НужноУведомление Тогда
			ДополнительныеСвойства.Вставить("ВКМ_СоздатьУведомлениеТелеграм", Истина);
			ДополнительныеСвойства.Вставить("ВКМ_ЭтоНовыйДокумент", ЭтоНовыйДокумент);
		КонецЕсли;
		
	
	//-- ВКМ
	
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	//++ ВКМ
	Если ДополнительныеСвойства.Свойство("ВКМ_СоздатьУведомлениеТелеграм") Тогда
		ЭтоНовыйДокумент = Ложь;
		ДополнительныеСвойства.Свойство("ВКМ_ЭтоНовыйДокумент", ЭтоНовыйДокумент);
		ТекстУведомления = ВКМ_Телеграм.ВКМ_СформироватьТекстУведомленияОбОбслуживании(ЭтотОбъект, ЭтоНовыйДокумент);
		ВКМ_Телеграм.ВКМ_ДобавитьУведомление(ТекстУведомления);
	КонецЕсли;
	//-- ВКМ
	
КонецПроцедуры
#КонецОбласти

#Область ВКМ_СлужебныеПроцедурыИФункции
Процедура ВКМ_ПроверитьУсловияПроведения(Отказ)
	
	Если Не ЗначениеЗаполнено(ВКМ_Специалист) Тогда
		ТекстСообщения = НСтр("ru = 'Не заполнен специалист.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, "ВКМ_Специалист", , Отказ);
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ВКМ_Договор) Тогда
		ТекстСообщения = НСтр("ru = 'Не заполнен договор.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, "ВКМ_Договор", , Отказ);
		Возврат;
	КонецЕсли;
	
	РеквизитыДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		ВКМ_Договор,
		"ВидДоговора, ВКМ_ДатаНачалаДействия, ВКМ_ДатаОкончанияДействия, ВКМ_СтоимостьЧасаРаботы");
	
	Если РеквизитыДоговора.ВидДоговора <> Перечисления.ВидыДоговоровКонтрагентов.ВКМ_АбонентскоеОбслуживание Тогда
		ТекстСообщения = НСтр("ru = 'Договор должен быть договором абонентского обслуживания.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, "ВКМ_Договор", , Отказ);
		Возврат;
	КонецЕсли;
	
	ДатаДокумента = НачалоДня(Дата);
	
	Если ЗначениеЗаполнено(РеквизитыДоговора.ВКМ_ДатаНачалаДействия)
		И ДатаДокумента < НачалоДня(РеквизитыДоговора.ВКМ_ДатаНачалаДействия) Тогда
		
		ТекстСообщения = НСтр("ru = 'Дата документа меньше даты начала действия договора.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, , , Отказ);
		Возврат;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РеквизитыДоговора.ВКМ_ДатаОкончанияДействия)
		И ДатаДокумента > НачалоДня(РеквизитыДоговора.ВКМ_ДатаОкончанияДействия) Тогда
		
		ТекстСообщения = НСтр("ru = 'Дата документа больше даты окончания действия договора.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, , , Отказ);
		Возврат;
		
	КонецЕсли;
	
	УсловияОплаты = ВКМ_ПолучитьПроцентОтРаботСотрудника(ВКМ_Специалист, Дата);
	Если Не УсловияОплаты.ЕстьУсловияОплаты Тогда
		ТекстСообщения = НСтр("ru = 'Невозможно провести документ: для сотрудника не задано условие оплаты на дату документа.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, "ВКМ_Специалист", , Отказ);
		Возврат;
	КонецЕсли;
	
КонецПроцедуры
Процедура ВКМ_СформироватьДвиженияПоВыполненнымРаботам()
	
	Если Не ЗначениеЗаполнено(ВКМ_Специалист) Тогда
		Возврат;
	КонецЕсли;
	
	УсловияОплаты = ВКМ_ПолучитьПроцентОтРаботСотрудника(ВКМ_Специалист, Дата);
	Если Не УсловияОплаты.ЕстьУсловияОплаты Тогда
		Возврат;
	КонецЕсли;
	
	СтавкаЧаса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВКМ_Договор, "ВКМ_СтоимостьЧасаРаботы");
	
	Для Каждого СтрокаРабот Из ВКМ_ВыполненныеРаботы Цикл
		
		ЧасыКОплате = СтрокаРабот.ВКМ_ЧасыКОплатеКлиенту;
		Если ЧасыКОплате <= 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ДвижениеКлиенту = Движения.ВКМ_ВыполненныеКлиентуРаботы.Добавить();
		ДвижениеКлиенту.Период = Дата;
		ДвижениеКлиенту.ВКМ_Клиент = ВКМ_Клиент;
		ДвижениеКлиенту.ВКМ_Договор = ВКМ_Договор;
		ДвижениеКлиенту.ВКМ_КоличествоЧасов = ЧасыКОплате;
		ДвижениеКлиенту.ВКМ_СуммаКОплате = ЧасыКОплате * СтавкаЧаса;
		
		ДвижениеСотруднику = Движения.ВКМ_ВыполненныеСотрудникомРаботы.Добавить();
		ДвижениеСотруднику.Период = Дата;
		
		ДвижениеСотруднику.Сотрудник = ВКМ_Специалист;
		ДвижениеСотруднику.ВКМ_ЧасовКОплате = ЧасыКОплате;
		ДвижениеСотруднику.ВКМ_СуммаКОплате = Окр(ЧасыКОплате * СтавкаЧаса * УсловияОплаты.ПроцентОтРабот / 100, 2);
		
	КонецЦикла;
	
КонецПроцедуры

//++ ВКМ
Функция ВКМ_ПолучитьСохраненныеЗначенияДляУведомления()
	
	Результат = Новый Структура(
		"ДатаПроведенияРабот, ВремяНачалаРабот, ВремяОкончанияРабот, Специалист",
		Дата(1, 1, 1),
		Дата(1, 1, 1),
		Дата(1, 1, 1),
		Справочники.Пользователи.ПустаяСсылка());
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Обслуживание.ВКМ_ДатаПроведенияРабот КАК ДатаПроведенияРабот,
	|	Обслуживание.ВКМ_ВремяНачалаРаботПлан КАК ВремяНачалаРабот,
	|	Обслуживание.ВКМ_ВремяОкончанияРаботПлан КАК ВремяОкончанияРабот,
	|	Обслуживание.ВКМ_Специалист КАК Специалист
	|ИЗ
	|	Документ.ВКМ_ОбслуживаниеКлиента КАК Обслуживание
	|ГДЕ
	|	Обслуживание.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

//++ ВКМ
Функция ВКМ_ПолучитьПроцентОтРаботСотрудника(Сотрудник, ДатаДокумента)
Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Условия.ПроцентОтРабот КАК ПроцентОтРабот
	|ИЗ
	|	РегистрСведений.ВКМ_УсловияОплатыСотрудников.СрезПоследних(
	|		&ДатаДокумента,
	|		Сотрудник = &Сотрудник) КАК Условия";
	
	Запрос.УстановитьПараметр("ДатаДокумента", ДатаДокумента);
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Новый Структура("ЕстьУсловияОплаты, ПроцентОтРабот", Истина, Выборка.ПроцентОтРабот);
	КонецЕсли;
	
	Возврат Новый Структура("ЕстьУсловияОплаты, ПроцентОтРабот", Ложь, 0);
КонецФункции
Функция ВКМ_РассчитатьЧасыПоВремени(ВремяНачала, ВремяОкончания)
	Если Не ЗначениеЗаполнено(ВремяНачала) Или Не ЗначениеЗаполнено(ВремяОкончания) Тогда
		Возврат 0;
	КонецЕсли;
	Секунд = ВремяОкончания - ВремяНачала;
	Если Секунд <= 0 Тогда
		Возврат 0;
	КонецЕсли;
	Возврат Окр(Секунд / 3600, 2);
КонецФункции
//-- ВКМ
#КонецОбласти
#КонецЕсли