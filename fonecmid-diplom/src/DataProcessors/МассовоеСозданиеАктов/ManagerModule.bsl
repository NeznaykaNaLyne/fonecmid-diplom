#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
#Область ПрограммныйИнтерфейс
// Заполнить табличную часть обработки в фоне.
Процедура ВКМ_ЗаполнитьТабличнуюЧастьВФоне(ПараметрыВыполнения, АдресРезультата) Экспорт
	
	Период = ПараметрыВыполнения.Период;
	ДанныеТабличнойЧасти = ВКМ_ПолучитьДанныеДоговоровЗаПериод(Период);
	
	ПоместитьВоВременноеХранилище(ДанныеТабличнойЧасти, АдресРезультата);
	
КонецПроцедуры
// Создать и провести реализации в фоне.

Процедура ВКМ_СоздатьРеализацииВФоне(ПараметрыВыполнения, АдресРезультата) Экспорт
	
	Период = ПараметрыВыполнения.Период;
	ТаблицаДоговоров = ПараметрыВыполнения.Договоры;
	
	ДатаДокумента = КонецМесяца(Период.ДатаОкончания);
	
	Для Каждого СтрокаДоговора Из ТаблицаДоговоров Цикл
		
		// Уже есть реализация за месяц — пропускаем.
		Если ЗначениеЗаполнено(СтрокаДоговора.ВКМ_Реализация) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СтрокаДоговора.ВКМ_Договор) Тогда
			Продолжить;
		КонецЕсли;
		

		СтрокаДоговора.ВКМ_Реализация = ВКМ_СоздатьИПровестиРеализацию(
			СтрокаДоговора.ВКМ_Договор,
			ДатаДокумента);
		
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(ТаблицаДоговоров, АдресРезультата);
	
КонецПроцедуры

#КонецОбласти
#Область СлужебныеПроцедурыИФункции
// Список абонентских договоров и уже созданных реализаций за месяц.
Функция ВКМ_ПолучитьДанныеДоговоровЗаПериод(Период)

	НачалоМесяца = НачалоМесяца(Период.ДатаНачала);
	КонецМесяца  = КонецМесяца(Период.ДатаОкончания);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Договоры.Ссылка КАК ВКМ_Договор,
	|	ЕСТЬNULL(Реализации.Ссылка, ЗНАЧЕНИЕ(Документ.РеализацияТоваровУслуг.ПустаяСсылка)) КАК ВКМ_Реализация
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК Договоры
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			Реализация.Договор КАК Договор,
	|			МАКСИМУМ(Реализация.Ссылка) КАК Ссылка
	|		ИЗ
	|			Документ.РеализацияТоваровУслуг КАК Реализация
	|		ГДЕ
	|			Реализация.Дата МЕЖДУ &НачалоМесяца И &КонецМесяца
	|			И НЕ Реализация.ПометкаУдаления
	|		СГРУППИРОВАТЬ ПО
	|			Реализация.Договор) КАК Реализации
	|		ПО Договоры.Ссылка = Реализации.Договор
	|ГДЕ
	|	Договоры.ВидДоговора = &ВидДоговора
	|	И НЕ Договоры.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВКМ_Договор";
	
	Запрос.УстановитьПараметр("НачалоМесяца", НачалоМесяца);
	Запрос.УстановитьПараметр("КонецМесяца", КонецМесяца);
	Запрос.УстановитьПараметр("ВидДоговора", Перечисления.ВидыДоговоровКонтрагентов.ВКМ_АбонентскоеОбслуживание);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Создать и провести одну реализацию.
Функция ВКМ_СоздатьИПровестиРеализацию(Договор, ДатаДокумента)
	
	ДокументОбъект = Документы.РеализацияТоваровУслуг.СоздатьДокумент();
	ДокументОбъект.Дата = ДатаДокумента;
	
	ДокументОбъект.Заполнить(Договор);
	ДокументОбъект.ВыполнитьАвтозаполнение();
	
	Если ДокументОбъект.Услуги.Количество() = 0
		И ДокументОбъект.Товары.Количество() = 0 Тогда
		
		ВызватьИсключение СтрШаблон(
			НСтр("ru = 'По договору %1 нечего реализовать за %2.'"),
			Договор,
			Формат(ДатаДокумента, "ДЛФ=D"));
		
	КонецЕсли;
	
	Если Не ДокументОбъект.ПроверитьЗаполнение() Тогда
		ВызватьИсключение СтрШаблон(
			НСтр("ru = 'Не заполнены обязательные реквизиты реализации по договору %1.'"),
			Договор);
	КонецЕсли;
	
	ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
	Возврат ДокументОбъект.Ссылка;
	
	
КонецФункции
// Проверка — есть ли уже реализация за месяц.

#КонецОбласти
#КонецЕсли